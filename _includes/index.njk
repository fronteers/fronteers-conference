{% extends "_includes/default.njk" %}
{% block content %}
  {% include '_partials/announcer.njk' %}

  <section class="narrow-width">
    <h3 class="headline">About Fronteers Dark Mode</h3>
    <p>Fronteers Dark Mode is a ~ 100 people, cozy, single-track afterwork front-end conference by and for the community. Taking place on Friday, October 2nd, 2026 at the atmospheric Cinema De Witt in Dordrecht, it offers an evening of inspiring talks on the material of the web, HTML, CSS, JS – and a nerdy late-night finale.</p>
  </section>

  {% include '_partials/cta.njk' %}

  {% set items = collections.speakers %}
  {% if items | length %}
    <section class="narrow-width">
      <ul class="cards full-width">
        {% asyncEach item in items|sortByAlphabet %}
        <li class="cards__item">
          {% set href = item.url %}
          {% set src = item.data.image %}
          {% set alt = 'Picture of ' ~ item.data.title %}
          {% set headline = item.data.title %}
          {% set text = item.data.talktitle %}
          <figure class="card">
            {% image src, alt, '9.375rem', 'lazy' %}
            <figcaption class="card__caption">
              <a href="{{ href }}" class="card__link">
                <h3 class="card__headline headline">{{ headline }}</h3>
                <p class="card__text">{{ text|safe }}</p>
              </a>
            </figcaption>
          </figure>
        </li>
        {% endeach %}
      </ul>
    </section>
  {% endif %}

  {% set src = '/img/venue.jpg' %}
  {% include '_partials/hero.njk' %}

  {% include '_partials/json-ld.njk' %}
{% endblock %}
